# ─────────────────────────────────────────
# Larry Inver Wholesale — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────

# Supabase (https://supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe (https://dashboard.stripe.com/apikeys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Resend (email — https://resend.com)
RESEND_API_KEY=re_your-resend-api-key

# Anthropic (AI assistant — https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Admin credentials (used by /admin-liwsecure)
ADMIN_EMAIL=admin@larryinverwholesale.com
ADMIN_PASS=ChangeThisToAStrongPassword123!

# Site
NEXT_PUBLIC_BASE_URL=https://larryinverwholesale.com
NEXT_PUBLIC_ADMIN_EMAIL=admin@larryinverwholesale.com
NEXT_PUBLIC_ADMIN_PASS=ChangeThisToAStrongPassword123!
